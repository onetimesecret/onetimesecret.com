---
/**
 * src/components/changelog/ScreenshotFrame.astro
 * Wraps a screenshot in a browser-window frame for consistent presentation.
 */
import { Image } from "astro:assets";

export interface Props {
  image: ImageMetadata;
  alt: string;
  caption?: string;
}

const { image, alt, caption } = Astro.props;
---

<figure class="not-prose my-8">
  <div
    class="overflow-hidden rounded-xl border border-surface-3 bg-surface-2
           shadow-lg">
    {/* Browser chrome */}
    <div
      class="flex items-center gap-2 border-b border-surface-3 bg-surface-1
             px-4 py-2.5">
      <div class="flex gap-1.5">
        <span class="size-3 rounded-full bg-rose-400/80 dark:bg-rose-500/60"
        ></span>
        <span
          class="size-3 rounded-full bg-amber-400/80 dark:bg-amber-500/60"
        ></span>
        <span
          class="size-3 rounded-full bg-emerald-400/80 dark:bg-emerald-500/60"
        ></span>
      </div>
      <div
        class="mx-auto max-w-xs flex-1 rounded-md bg-surface-2 px-3 py-1
               text-center text-xs text-text-tertiary">
        onetimesecret.com
      </div>
    </div>
    {/* Screenshot */}
    <Image
      src={image}
      alt={alt}
      widths={[640, 960, 1280]}
      sizes="(max-width: 768px) 100vw, 720px"
      class="w-full object-cover"
    />
  </div>
  {
    caption && (
      <figcaption class="mt-3 text-center text-sm text-text-tertiary">
        {caption}
      </figcaption>
    )
  }
</figure>
