---
/**
 * src/components/changelog/Callout.astro
 * Highlighted box for tips, info, or warning notes inside changelog entries.
 */

export interface Props {
  type?: "info" | "warning" | "tip";
}

const { type = "info" } = Astro.props;

const config = {
  info: {
    icon: "M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z",
    classes:
      "border-brandcomp-300 bg-brandcomp-50 " +
      "dark:border-brandcomp-700 dark:bg-brandcomp-950/30",
    iconColor: "text-brandcomp-600 dark:text-brandcomp-400",
  },
  warning: {
    icon: "M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z",
    classes:
      "border-amber-300 bg-amber-50 " +
      "dark:border-amber-700 dark:bg-amber-950/30",
    iconColor: "text-amber-600 dark:text-amber-400",
  },
  tip: {
    icon: "M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18",
    classes:
      "border-emerald-300 bg-emerald-50 " +
      "dark:border-emerald-700 dark:bg-emerald-950/30",
    iconColor: "text-emerald-600 dark:text-emerald-400",
  },
};

const c = config[type];
---

<aside
  class:list={[
    "not-prose my-6 flex gap-3 rounded-lg border p-4",
    c.classes,
  ]}
  role="note">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    viewBox="0 0 24 24"
    stroke-width="1.5"
    stroke="currentColor"
    class:list={["mt-0.5 size-5 shrink-0", c.iconColor]}
    aria-hidden="true">
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d={c.icon}
    />
  </svg>
  <div class="text-sm leading-relaxed text-text-primary">
    <slot />
  </div>
</aside>
