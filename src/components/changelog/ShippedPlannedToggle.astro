---
/**
 * src/components/changelog/ShippedPlannedToggle.astro
 * Segmented control toggling between shipped and planned entry lists.
 * Both lists are rendered statically; a small inline script toggles visibility.
 * No framework dependencies.
 */

export interface Props {
  shippedLabel?: string;
  plannedLabel?: string;
  plannedCount?: number;
}

const {
  shippedLabel = "Shipped",
  plannedLabel = "Planned",
  plannedCount = 0,
} = Astro.props;
---

<div class="inline-flex items-center gap-1 rounded-xl bg-surface-2 p-1"
     role="tablist"
     aria-label="Update status filter">
  <button
    role="tab"
    aria-selected="true"
    aria-controls="changelog-shipped"
    id="tab-shipped"
    class="changelog-tab rounded-lg px-4 py-1.5 text-sm font-medium
           transition-colors bg-surface-0 text-text-primary shadow-sm"
    data-target="shipped">
    {shippedLabel}
  </button>
  <button
    role="tab"
    aria-selected="false"
    aria-controls="changelog-planned"
    id="tab-planned"
    class="changelog-tab rounded-lg px-4 py-1.5 text-sm font-medium
           transition-colors text-text-tertiary hover:text-text-secondary"
    data-target="planned">
    {plannedLabel}
    {
      plannedCount > 0 && (
        <span
          class="ml-1.5 inline-flex size-5 items-center justify-center
                 rounded-full bg-surface-3 text-xs text-text-tertiary">
          {plannedCount}
        </span>
      )
    }
  </button>
</div>

<script>
  // Use DOMContentLoaded — this site does not use Astro View Transitions,
  // so astro:page-load never fires.
  document.addEventListener("DOMContentLoaded", () => {
    const tabs = document.querySelectorAll<HTMLButtonElement>(".changelog-tab");
    const shipped = document.getElementById("changelog-shipped");
    const planned = document.getElementById("changelog-planned");
    if (!shipped || !planned || tabs.length === 0) return;

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const target = tab.dataset.target;
        const isShipped = target === "shipped";

        shipped.classList.toggle("hidden", !isShipped);
        planned.classList.toggle("hidden", isShipped);

        tabs.forEach((t) => {
          const active = t.dataset.target === target;
          t.setAttribute("aria-selected", String(active));
          t.classList.toggle("bg-surface-0", active);
          t.classList.toggle("text-text-primary", active);
          t.classList.toggle("shadow-sm", active);
          t.classList.toggle("text-text-tertiary", !active);
        });
      });
    });
  });
</script>
