---
/**
 * src/components/changelog/StatsHeader.astro
 * Displays total shipped entry count and most recent entry date.
 */
import {
  createLocaleI18n,
  type MessageSchema,
  type SupportedLanguage,
} from "@/i18n";

export interface Props {
  totalEntries: number;
  latestDate: Date;
  locale: string;
  initialMessages?: Record<string, MessageSchema>;
}

const { totalEntries, latestDate, locale, initialMessages } = Astro.props;

const pageI18n = await createLocaleI18n(
  locale as SupportedLanguage,
  initialMessages,
);
const t = pageI18n.global.t;

const formattedDate = latestDate.toLocaleDateString(locale, {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});

const updatesLabel =
  totalEntries === 1
    ? t("changelog.stats-update-singular")
    : t("changelog.stats-update-plural");
---

<div
  class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm
         text-text-tertiary">
  <span>
    <span class="font-semibold text-text-secondary">{totalEntries}</span>
    {updatesLabel}
  </span>
  <span class="hidden sm:inline" aria-hidden="true">&middot;</span>
  <span>
    {t("changelog.stats-latest")}: <time datetime={latestDate.toISOString()}>{formattedDate}</time>
  </span>
</div>
