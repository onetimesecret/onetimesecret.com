---
/**
 * src/components/changelog/EntryCard.astro
 * Card component for the changelog index page.
 * Renders hero image (if present), category badge, date, title, and description.
 */
import { Image } from "astro:assets";
import CategoryBadge from "./CategoryBadge.astro";

export interface Props {
  slug: string;
  title: string;
  date: Date;
  description: string;
  category: "new" | "improved" | "fixed" | "security";
  categoryLabel?: string;
  image?: ImageMetadata;
  imageAlt?: string;
  featured?: boolean;
  locale: string;
}

const {
  slug,
  title,
  date,
  description,
  category,
  categoryLabel,
  image,
  imageAlt,
  locale,
} = Astro.props;

const formattedDate = date.toLocaleDateString(locale, {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const entryUrl = `/${locale}/changelog/${slug}`;
---

<article
  class="group grid grid-cols-1 gap-x-8 md:grid-cols-[140px_1fr]">
  {/* Date column (visible on md+) */}
  <div class="hidden pt-1 md:block">
    <time
      datetime={date.toISOString()}
      class="text-sm text-text-tertiary">
      {formattedDate}
    </time>
  </div>

  {/* Entry card */}
  <div
    class="overflow-hidden rounded-xl border border-surface-3 bg-surface-1
           transition-colors hover:border-surface-4">
    {
      image && (
        <a
          href={entryUrl}
          class="block overflow-hidden">
          <Image
            src={image}
            alt={imageAlt || title}
            widths={[640, 960]}
            sizes="(max-width: 768px) 100vw, 720px"
            class="w-full object-cover transition-transform duration-300
                   group-hover:scale-[1.02]"
          />
        </a>
      )
    }
    <div class="p-5 sm:p-6">
      <div class="mb-3 flex flex-wrap items-center gap-3">
        <CategoryBadge category={category} label={categoryLabel} />
        <time
          datetime={date.toISOString()}
          class="text-sm text-text-tertiary md:hidden">
          {formattedDate}
        </time>
      </div>
      <h2 class="mb-2 text-xl font-bold tracking-tight text-text-primary">
        <a
          href={entryUrl}
          class="hover:text-brand-500 transition-colors dark:hover:text-brand-400">
          {title}
        </a>
      </h2>
      <p class="text-base leading-relaxed text-text-secondary">
        {description}
      </p>
    </div>
  </div>
</article>
