---
/**
 * src/components/changelog/EntryCard.astro
 * Card component for the changelog index page.
 * Two-column layout: narrow date column, wide entry card.
 * No hero image on the card — images appear only on the full entry page.
 */
import CategoryBadge from "./CategoryBadge.astro";
import EntryHighlights from "./EntryHighlights.astro";
import type { HighlightItem } from "./highlights";

export interface Props {
  slug: string;
  title: string;
  date: Date;
  description: string;
  category: "new" | "improved" | "fixed" | "security";
  categoryLabel?: string;
  githubRelease?: string;
  locale: string;
  highlights?: HighlightItem[];
}

const {
  slug,
  title,
  date,
  description,
  category,
  categoryLabel,
  githubRelease,
  locale,
  highlights,
} = Astro.props;

const formattedDate = date.toLocaleDateString(locale, {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const entryUrl = `/${locale}/changelog/${slug}`;
---

<article
  class="group grid grid-cols-1 gap-x-8 md:grid-cols-[140px_1fr]">
  {/* Date column (visible on md+) */}
  <div class="hidden pt-1 md:block">
    <time
      datetime={date.toISOString()}
      class="text-sm text-text-tertiary">
      {formattedDate}
    </time>
  </div>

  {/* Entry card */}
  <div
    class="overflow-hidden rounded-xl border border-surface-3 bg-surface-1
           p-5 transition-colors hover:border-surface-4 sm:p-6">
    <div class="mb-3 flex flex-wrap items-center gap-3">
      <CategoryBadge category={category} label={categoryLabel} />
      <time
        datetime={date.toISOString()}
        class="text-sm text-text-tertiary md:hidden">
        {formattedDate}
      </time>
    </div>
    <h2 class="mb-2 text-xl font-bold tracking-tight text-text-primary">
      <a
        href={entryUrl}
        class="transition-colors hover:text-brand-500
               dark:hover:text-brand-400">
        {title}
      </a>
    </h2>
    <p class="text-base leading-relaxed text-text-secondary">
      {description}
    </p>
    <EntryHighlights highlights={highlights} />
    {
      githubRelease && (
        <a
          href={githubRelease}
          class="mt-3 inline-flex items-center gap-1 text-sm font-medium
                 text-text-tertiary transition-colors hover:text-brand-500
                 dark:hover:text-brand-400"
          target="_blank"
          rel="noopener noreferrer">
          <span>&rarr;</span> GitHub release notes
        </a>
      )
    }
  </div>
</article>
