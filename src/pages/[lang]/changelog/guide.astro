---
/**
 * src/pages/[lang]/changelog/guide.astro
 *
 * Visual Production Workflow — Runbook & Interactive Documentation
 *
 * An unlinked reference page for content authors. Demonstrates every
 * changelog MDX component with live rendered examples and copy-pasteable
 * code snippets. Follow the steps here when creating a new changelog entry.
 *
 * Structure (runbook-first):
 *   1. Quick-start checklist
 *   2. Entry types at a glance (decision point → anchor links to components)
 *   3. Frontmatter template
 *   4. Category badges
 *   5. Screenshot workflow
 *   6. Component reference (ScreenshotFrame, BeforeAfter, VideoEmbed, Callout)
 *   7. Screenshot consistency rules
 *   8. Full example entry
 *   9. File structure reference
 */
import Layout from "@/layouts/Layout.astro";
import Prose from "@/components/vue/Prose.astro";
import CategoryBadge from "@/components/changelog/CategoryBadge.astro";
import EntryHighlights from "@/components/changelog/EntryHighlights.astro";
import ScreenshotFrame from "@/components/changelog/ScreenshotFrame.astro";
import BeforeAfter from "@/components/changelog/BeforeAfter.astro";
import VideoEmbed from "@/components/changelog/VideoEmbed.astro";
import Callout from "@/components/changelog/Callout.astro";
import { getLanguagePaths } from "@/i18n";
import type { MessageSchema } from "@/i18n";

import sampleScreenshot from "@/assets/changelog-guide/sample-screenshot.png";
import sampleBefore from "@/assets/changelog-guide/sample-before.png";
import sampleAfter from "@/assets/changelog-guide/sample-after.png";

export async function getStaticPaths() {
  return getLanguagePaths();
}

const { lang } = Astro.params;
const { initialMessages } = Astro.props;
---

<Layout
  title="Changelog Guide | Onetime Secret"
  description="Visual production workflow and component reference for creating changelog entries."
  htmlLang={lang}
  noindex={true}
  initialMessages={initialMessages as Record<string, MessageSchema>}>
  {/* ── Header ────────────────────────────────────────────────── */}
  <div class="border-surface-3 bg-surface-0 border-b py-12 sm:py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <p class="section-label mb-3">changelog</p>
      <h1
        class="font-brand text-text-primary text-3xl font-bold tracking-tight sm:text-4xl">
        A Visual Production Guide
      </h1>
      <p class="text-text-secondary mt-4 text-lg">
        A playbook for maintaining changelog entries. Every component is
        rendered live below with copy-pasteable code.
      </p>
    </div>
  </div>

  <div class="mx-auto max-w-3xl px-4 py-10 sm:px-6 sm:py-14">
    {
      /* ═══════════════════════════════════════════════════════════
        1. Quick-start checklist
        ═══════════════════════════════════════════════════════════ */
    }
    <Prose>
      <h2>Quick-start checklist</h2>
      <ol>
        <li>
          Decide which <a href="#entry-types">entry type</a> you're creating (standard,
          text-only, or major feature).
        </li>
        <li>
          Create a directory under <code>src/content/changelog/</code>
          named with the pattern <code>YYYY-MM-DD-slug</code>
          (e.g. <code>2026-04-15-passphrase-hints</code>).
        </li>
        <li>
          Add an <code>index.mdx</code> file with the required frontmatter (see <a
            href="#frontmatter-template">template below</a
          >).
        </li>
        <li>
          Capture your screenshot at <strong>1280&times;800</strong> and save it as
          <code>hero.png</code> in the same directory.
        </li>
        <li>Write 2-4 sentences describing the user benefit.</li>
        <li>Import any components you need at the top of the MDX file.</li>
        <li>Commit, push, rebuild.</li>
      </ol>
    </Prose>

    {
      /* ═══════════════════════════════════════════════════════════
        2. Entry types at a glance (decision point)
        ═══════════════════════════════════════════════════════════ */
    }
    <section
      id="entry-types"
      class="mt-14">
      <Prose>
        <h2>Entry types at a glance</h2>
        <p>
          Start here. Pick the tier that matches your change, then follow the
          links to the components you'll need.
        </p>
      </Prose>
      <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-3">
        <div class="border-surface-3 bg-surface-1 rounded-lg border p-5">
          <p class="text-text-primary mb-3 text-sm font-semibold">
            Standard entry (~5 min)
          </p>
          <ul class="text-text-secondary space-y-1 text-sm">
            <li>One hero screenshot</li>
            <li>
              <a
                href="#comp-screenshotframe"
                class="text-brandcomp-600 hover:text-brandcomp-500 dark:text-brandcomp-400 dark:hover:text-brandcomp-300">
                ScreenshotFrame
              </a> component
            </li>
            <li>2-4 sentence description</li>
            <li>
              One <a
                href="#comp-callout"
                class="text-brandcomp-600 hover:text-brandcomp-500 dark:text-brandcomp-400 dark:hover:text-brandcomp-300">
                Callout
              </a> if needed
            </li>
          </ul>
        </div>
        <div class="border-surface-3 bg-surface-1 rounded-lg border p-5">
          <p class="text-text-primary mb-3 text-sm font-semibold">
            Text-only entry (~3 min)
          </p>
          <ul class="text-text-secondary space-y-1 text-sm">
            <li>No <code>image</code> in frontmatter</li>
            <li>For backend, security, or performance changes</li>
            <li>
              <a
                href="#comp-callout"
                class="text-brandcomp-600 hover:text-brandcomp-500 dark:text-brandcomp-400 dark:hover:text-brandcomp-300">
                Callout
              </a> for key takeaway
            </li>
            <li>Keep it concise</li>
          </ul>
        </div>
        <div class="border-surface-3 bg-surface-1 rounded-lg border p-5">
          <p class="text-text-primary mb-3 text-sm font-semibold">
            Major feature (~15 min)
          </p>
          <ul class="text-text-secondary space-y-1 text-sm">
            <li>
              Hero screenshot +
              <a
                href="#comp-beforeafter"
                class="text-brandcomp-600 hover:text-brandcomp-500 dark:text-brandcomp-400 dark:hover:text-brandcomp-300">
                BeforeAfter
              </a>
            </li>
            <li>
              15-30s
              <a
                href="#comp-videoembed"
                class="text-brandcomp-600 hover:text-brandcomp-500 dark:text-brandcomp-400 dark:hover:text-brandcomp-300">
                video walkthrough
              </a>
            </li>
            <li>Longer narrative, multiple sections</li>
            <li>Set <code>featured: true</code></li>
          </ul>
        </div>
      </div>
    </section>

    {
      /* ═══════════════════════════════════════════════════════════
        3. Frontmatter template
        ═══════════════════════════════════════════════════════════ */
    }
    <section
      id="frontmatter-template"
      class="mt-14">
      <Prose>
        <h2>Frontmatter template</h2>
        <p>
          Copy this into your <code>index.mdx</code> and fill in the fields. The <code
            >image</code
          >, <code>featured</code>, <code>highlightedLinkUrl</code>, <code
            >highlightedLinkText</code
          >, <code>planned</code>, and <code>highlights</code> fields are optional.
        </p>
      </Prose>
      <div
        class="code-block group border-surface-3 relative mt-4 overflow-x-auto rounded-lg border bg-slate-900 p-4 text-sm leading-relaxed text-slate-300">
        <button
          class="copy-btn absolute top-2.5 right-2.5 rounded-md bg-slate-700/60 px-2 py-1 text-xs text-slate-400 opacity-0 transition-opacity group-hover:opacity-100 hover:bg-slate-600/80 hover:text-slate-200 focus:opacity-100"
          aria-label="Copy to clipboard">
          Copy
        </button>
        <pre><code>{`---
title: "Plain-language headline focused on user benefit"
date: 2026-04-01
description: "2-4 sentence summary shown on the index card and RSS feed."
category: "release"        # release | news | operations | security
image: "./hero.png"        # optional — relative to this directory
imageAlt: "Descriptive alt text for the hero image"
featured: false            # true → richer treatment on index
highlightedLinkUrl: "https://github.com/onetimesecret/onetimesecret/releases/tag/v1.0"
highlightedLinkText: "GitHub release notes"
planned: false             # true → appears in Planned tab only
highlights:                # optional bullet list shown on the index card
  - { icon: check, text: "Something done, shipped, or fixed" }
  - { icon: info,  text: "Neutral supporting detail" }
  - { icon: warn,  text: "Caution or behaviour change" }
  - { icon: ask,   text: "Open question or planned / pending work" }
---

import Callout from "@/components/changelog/Callout.astro";
import ScreenshotFrame from "@/components/changelog/ScreenshotFrame.astro";

Your markdown content starts here.`}</code></pre>
      </div>
    </section>

    {
      /* ═══════════════════════════════════════════════════════════
        4. Category badges
        ═══════════════════════════════════════════════════════════ */
    }
    <section class="mt-14">
      <Prose>
        <h2>Category badges</h2>
        <p>
          Every entry gets exactly one category. Pick the one that best
          describes the change from the customer's perspective.
        </p>
      </Prose>
      <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
        <div class="border-surface-3 bg-surface-1 rounded-lg border p-5">
          <div class="mb-2">
            <CategoryBadge category="release" />
          </div>
          <p class="text-text-secondary text-sm">
            <strong class="text-text-primary">Release</strong> — A new version of
            the software shipping.
          </p>
        </div>
        <div class="border-surface-3 bg-surface-1 rounded-lg border p-5">
          <div class="mb-2">
            <CategoryBadge category="news" />
          </div>
          <p class="text-text-secondary text-sm">
            <strong class="text-text-primary">News</strong> — Announcements: region
            launches, documentation moves, partnerships, policy changes, company updates.
          </p>
        </div>
        <div class="border-surface-3 bg-surface-1 rounded-lg border p-5">
          <div class="mb-2">
            <CategoryBadge category="operations" />
          </div>
          <p class="text-text-secondary text-sm">
            <strong class="text-text-primary">Operations</strong> — Infrastructure
            and service events: regional rollouts, upgrades, deployments, incident
            resolutions.
          </p>
        </div>
        <div class="border-surface-3 bg-surface-1 rounded-lg border p-5">
          <div class="mb-2">
            <CategoryBadge category="security" />
          </div>
          <p class="text-text-secondary text-sm">
            <strong class="text-text-primary">Security</strong> — Security advisories,
            vulnerability disclosures, and protective measures worth their own visibility.
          </p>
        </div>
      </div>
    </section>

    {
      /* ═══════════════════════════════════════════════════════════
        4b. Highlight bullets
        ═══════════════════════════════════════════════════════════ */
    }
    <section class="mt-14">
      <Prose>
        <h2>Highlight bullets</h2>
        <p>
          The optional <code>highlights</code> field renders a short bullet list
          on the index card. Each item picks one of four icons. Stick to the
          legend &mdash; the colour is canonical, don't re-tint.
        </p>
      </Prose>
      <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
        <div class="border-surface-3 bg-surface-1 rounded-lg border p-5">
          <p class="text-text-primary mb-1 text-sm font-semibold">
            <code>check</code> &mdash; green
          </p>
          <p class="text-text-secondary text-sm">
            Something done, verified, shipped, or fixed.
          </p>
        </div>
        <div class="border-surface-3 bg-surface-1 rounded-lg border p-5">
          <p class="text-text-primary mb-1 text-sm font-semibold">
            <code>info</code> &mdash; sky
          </p>
          <p class="text-text-secondary text-sm">
            Neutral supporting detail. The "for instance" bullet.
          </p>
        </div>
        <div class="border-surface-3 bg-surface-1 rounded-lg border p-5">
          <p class="text-text-primary mb-1 text-sm font-semibold">
            <code>warn</code> &mdash; amber
          </p>
          <p class="text-text-secondary text-sm">
            Caution, constraint, or behaviour change worth flagging.
          </p>
        </div>
        <div class="border-surface-3 bg-surface-1 rounded-lg border p-5">
          <p class="text-text-primary mb-1 text-sm font-semibold">
            <code>ask</code> &mdash; violet
          </p>
          <p class="text-text-secondary text-sm">
            Open question or planned / pending work. Pair with <code
              >planned: true</code
            >.
          </p>
        </div>
      </div>

      {/* Live example */}
      <div
        class="border-surface-4 bg-surface-0 mt-6 rounded-xl border border-dashed p-4 sm:p-6">
        <p class="section-label mb-4">Live preview</p>
        <EntryHighlights
          highlights={[
            { icon: "check", text: "Passphrase hint shipped behind feature flag" },
            { icon: "info", text: "Defaults to off for self-hosted instances" },
            { icon: "warn", text: "Old API field renamed; clients must update" },
            { icon: "ask", text: "Localized hint strings still pending translation" },
          ]}
        />
      </div>

      {/* Code */}
      <div
        class="code-block group border-surface-3 relative mt-4 overflow-x-auto rounded-lg border bg-slate-900 p-4 text-sm leading-relaxed text-slate-300">
        <button
          class="copy-btn absolute top-2.5 right-2.5 rounded-md bg-slate-700/60 px-2 py-1 text-xs text-slate-400 opacity-0 transition-opacity group-hover:opacity-100 hover:bg-slate-600/80 hover:text-slate-200 focus:opacity-100"
          aria-label="Copy to clipboard">
          Copy
        </button>
        <pre><code>{`highlights:
  - { icon: check, text: "Passphrase hint shipped behind feature flag" }
  - { icon: info,  text: "Defaults to off for self-hosted instances" }
  - { icon: warn,  text: "Old API field renamed; clients must update" }
  - { icon: ask,   text: "Localized hint strings still pending translation" }`}</code></pre>
      </div>
    </section>

    {
      /* ═══════════════════════════════════════════════════════════
        5. Screenshot workflow
        ═══════════════════════════════════════════════════════════ */
    }
    <section class="mt-14">
      <Prose>
        <h2>Screenshot workflow (~5 min)</h2>
        <p>
          Most entries need one screenshot. Follow these steps for consistent
          results every time.
        </p>
        <ol>
          <li>
            Deploy the feature to <strong>staging</strong> or
            <strong>production</strong>.
          </li>
          <li>
            Open the relevant page in Chrome. Set the viewport to
            <strong>1280&times;800</strong> via DevTools
            <span class="text-text-tertiary">
              (Device toolbar &rarr; Responsive &rarr; 1280 &times; 800)
            </span>.
          </li>
          <li>
            Screenshot the key UI state.
            <ul>
              <li>
                macOS: <kbd>Cmd+Shift+4</kbd> (region) or DevTools &rarr; <em
                  >Capture screenshot</em
                >
              </li>
              <li>
                Linux/Windows: DevTools &rarr; <kbd>Ctrl+Shift+P</kbd>
                &rarr; <em>"Capture full size screenshot"</em>
              </li>
            </ul>
          </li>
          <li>
            Save the file as <code>hero.png</code> inside your entry directory.
          </li>
          <li>
            Wrap it in a
            <a href="#comp-screenshotframe">ScreenshotFrame</a> component for consistent
            browser-chrome framing.
          </li>
        </ol>
      </Prose>
    </section>

    {
      /* ═══════════════════════════════════════════════════════════
        6a. Component: ScreenshotFrame
        ═══════════════════════════════════════════════════════════ */
    }
    <section class="mt-14">
      <Prose>
        <h2 id="comp-screenshotframe">Component: ScreenshotFrame</h2>
        <p>
          Wraps a raw screenshot in a browser-window frame with traffic-light
          dots and an address bar. Use this for most entries — it adds visual
          polish without any extra work.
        </p>
      </Prose>

      {/* Live example */}
      <div
        class="border-surface-4 bg-surface-0 mt-6 rounded-xl border border-dashed p-4 sm:p-6">
        <p class="section-label mb-4">Live preview</p>
        <ScreenshotFrame
          image={sampleScreenshot}
          alt="Sample screenshot showing the secret creation form"
          caption="This caption appears below the frame."
        />
      </div>

      {/* Code */}
      <div
        class="code-block group border-surface-3 relative mt-4 overflow-x-auto rounded-lg border bg-slate-900 p-4 text-sm leading-relaxed text-slate-300">
        <button
          class="copy-btn absolute top-2.5 right-2.5 rounded-md bg-slate-700/60 px-2 py-1 text-xs text-slate-400 opacity-0 transition-opacity group-hover:opacity-100 hover:bg-slate-600/80 hover:text-slate-200 focus:opacity-100"
          aria-label="Copy to clipboard">
          Copy
        </button>
        <pre><code>{`import ScreenshotFrame from "@/components/changelog/ScreenshotFrame.astro";

<ScreenshotFrame
  image={import("./hero.png")}
  alt="What the screenshot shows"
  caption="Optional caption below the frame."
/>`}</code></pre>
      </div>
    </section>

    {
      /* ═══════════════════════════════════════════════════════════
        6b. Component: BeforeAfter
        ═══════════════════════════════════════════════════════════ */
    }
    <section class="mt-14">
      <Prose>
        <h2 id="comp-beforeafter">Component: BeforeAfter</h2>
        <p>
          Side-by-side comparison (stacked on mobile). Use when a change is best
          understood by contrasting the old and new states. Save two images — <code
            >before.png</code
          > and
          <code>after.png</code> — in your entry directory.
        </p>
      </Prose>

      {/* Live example */}
      <div
        class="border-surface-4 bg-surface-0 mt-6 rounded-xl border border-dashed p-4 sm:p-6">
        <p class="section-label mb-4">Live preview</p>
        <BeforeAfter
          before={sampleBefore}
          after={sampleAfter}
          beforeAlt="The old interface before the change"
          afterAlt="The new interface after the change"
          caption="Label your before/after images clearly."
        />
      </div>

      {/* Code */}
      <div
        class="code-block group border-surface-3 relative mt-4 overflow-x-auto rounded-lg border bg-slate-900 p-4 text-sm leading-relaxed text-slate-300">
        <button
          class="copy-btn absolute top-2.5 right-2.5 rounded-md bg-slate-700/60 px-2 py-1 text-xs text-slate-400 opacity-0 transition-opacity group-hover:opacity-100 hover:bg-slate-600/80 hover:text-slate-200 focus:opacity-100"
          aria-label="Copy to clipboard">
          Copy
        </button>
        <pre><code>{`import BeforeAfter from "@/components/changelog/BeforeAfter.astro";

<BeforeAfter
  before={import("./before.png")}
  after={import("./after.png")}
  beforeAlt="Description of the before state"
  afterAlt="Description of the after state"
  caption="Optional caption below both images."
/>`}</code></pre>
      </div>
    </section>

    {
      /* ═══════════════════════════════════════════════════════════
        6c. Component: VideoEmbed
        ═══════════════════════════════════════════════════════════ */
    }
    <section class="mt-14">
      <Prose>
        <h2 id="comp-videoembed">Component: VideoEmbed</h2>
        <p>
          Responsive video player for walkthroughs. Supports local MP4 files or
          privacy-respecting YouTube embeds via
          <code>youtube-nocookie.com</code> (no tracking cookies, GDPR-friendly).
          Use for major features where a static screenshot doesn't capture the interaction.
        </p>
        <h3>Recording tips (macOS)</h3>
        <ol>
          <li>
            <kbd>Cmd+Shift+5</kbd> &rarr; <em>Record Selected Portion</em>
          </li>
          <li>Set the recording region to 1280&times;800</li>
          <li>Keep it to 15-30 seconds — show the core flow, skip setup</li>
          <li>Trim in QuickTime (<em>Edit &rarr; Trim</em>), export as MP4</li>
          <li>Save as <code>walkthrough.mp4</code> in the entry directory</li>
        </ol>
      </Prose>

      {/* Live example — Astro intro video (public, embeddable) */}
      <div
        class="border-surface-4 bg-surface-0 mt-6 rounded-xl border border-dashed p-4 sm:p-6">
        <p class="section-label mb-4">
          Live preview (YouTube embed via youtube-nocookie.com)
        </p>
        <VideoEmbed
          youtube="gxBkghlglTg"
          title="Astro in 100 Seconds — example embed"
          caption="Example embed showing an Astro overview video."
        />
      </div>

      {/* Code */}
      <div
        class="code-block group border-surface-3 relative mt-4 overflow-x-auto rounded-lg border bg-slate-900 p-4 text-sm leading-relaxed text-slate-300">
        <button
          class="copy-btn absolute top-2.5 right-2.5 rounded-md bg-slate-700/60 px-2 py-1 text-xs text-slate-400 opacity-0 transition-opacity group-hover:opacity-100 hover:bg-slate-600/80 hover:text-slate-200 focus:opacity-100"
          aria-label="Copy to clipboard">
          Copy
        </button>
        <pre><code>{`import VideoEmbed from "@/components/changelog/VideoEmbed.astro";

<!-- Local MP4 (place file in public/videos/changelog/) -->
<VideoEmbed src="/videos/changelog/walkthrough.mp4" caption="Quick walkthrough." />

<!-- YouTube (embedded via youtube-nocookie.com for privacy) -->
<VideoEmbed
  youtube="VIDEO_ID"
  title="Descriptive title for accessibility"
  caption="Optional caption."
  aspectRatio="16/9"
/>`}</code></pre>
      </div>
    </section>

    {
      /* ═══════════════════════════════════════════════════════════
        6d. Component: Callout
        ═══════════════════════════════════════════════════════════ */
    }
    <section class="mt-14">
      <Prose>
        <h2 id="comp-callout">Component: Callout</h2>
        <p>
          Highlighted box for supplementary information. Three variants for
          different contexts. Choose the type that matches the tone of the
          message.
        </p>
      </Prose>

      {/* Live examples — all three variants */}
      <div
        class="border-surface-4 bg-surface-0 mt-6 rounded-xl border border-dashed p-4 sm:p-6">
        <p class="section-label mb-4">Live preview — info variant</p>
        <Callout type="info">
          <strong>Info</strong> — Use for supplementary context. "This feature is
          available on all plans, including free."
        </Callout>

        <p class="section-label mt-6 mb-4">Live preview — tip variant</p>
        <Callout type="tip">
          <strong>Tip</strong> — Use for helpful suggestions. "Set an expiration time
          as a backup in case the recipient doesn't open the link."
        </Callout>

        <p class="section-label mt-6 mb-4">Live preview — warning variant</p>
        <Callout type="warning">
          <strong>Warning</strong> — Use for important caveats. "Secrets with passphrases
          cannot be recovered if the passphrase is lost."
        </Callout>
      </div>

      {/* Code */}
      <div
        class="code-block group border-surface-3 relative mt-4 overflow-x-auto rounded-lg border bg-slate-900 p-4 text-sm leading-relaxed text-slate-300">
        <button
          class="copy-btn absolute top-2.5 right-2.5 rounded-md bg-slate-700/60 px-2 py-1 text-xs text-slate-400 opacity-0 transition-opacity group-hover:opacity-100 hover:bg-slate-600/80 hover:text-slate-200 focus:opacity-100"
          aria-label="Copy to clipboard">
          Copy
        </button>
        <pre><code>{`import Callout from "@/components/changelog/Callout.astro";

<Callout type="info">Informational note.</Callout>
<Callout type="tip">Helpful suggestion.</Callout>
<Callout type="warning">Important caveat.</Callout>`}</code></pre>
      </div>
    </section>

    {
      /* ═══════════════════════════════════════════════════════════
        7. Screenshot consistency rules
        ═══════════════════════════════════════════════════════════ */
    }
    <section class="mt-14">
      <Prose>
        <h2>Screenshot consistency rules</h2>
      </Prose>
      <div
        class="border-surface-3 bg-surface-3 mt-4 grid grid-cols-1 gap-px overflow-hidden rounded-xl border">
        {
          [
            {
              rule: "Viewport size",
              detail:
                "Always 1280\u00d7800. Set via Chrome DevTools device toolbar.",
            },
            {
