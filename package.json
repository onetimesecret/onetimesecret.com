{
  "version": "3.2.0-alpha",
  "type": "module",
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "check": "astro check --tsconfig tsconfig.json",
    "clean": "rm -rf dist/ .astro/ node_modules/.vite/",
    "reinstall": "pnpm clean && pnpm install",
    "dev": "NODE_OPTIONS='--max-old-space-size=8192 --trace-warnings' astro dev --host",
    "lint": "pnpm run lint:base --cache-location ./node_modules/.cache/eslint --cache 'src/**/*.{mjs,ts,d.ts,vue}' './*.{mjs,ts,js}'",
    "lint:base": "eslint --quiet --config eslint.config.ts",
    "lint:fix": "pnpm run lint:base --fix 'src/**/*.{mjs,ts,vue}' './*.{mjs,ts,d.ts,vue}'",
    "lint:quick": "pnpm run lint:base --cache-location ./node_modules/.cache/eslint --cache 'src/**/*.{mjs,ts}' './*.{mjs,ts,js}'",
    "lint:quick:fix": "pnpm run lint:base --fix 'src/**/*.{mjs,ts}' './*.{mjs,ts,d.ts,js}'",
    "lint:tests": "pnpm run lint:base 'tests/**/*.{mjs,ts,vue}'",
    "preview": "astro preview --host",
    "type-check:base": "vue-tsc --noEmit",
    "type-check": "pnpm run type-check:base",
    "type-check:watch": "pnpm run type-check:base --watch",
    "i18n:scan": "vue-i18n-extract --vueFiles \"./src/**/*.?(js|ts|vue|astro|mdx|jsx)\" --languageFiles \"./src/i18n/ui/*.json\"",
    "i18n:add": "vue-i18n-extract --vueFiles \"./src/**/*.?(js|ts|vue|astro|mdx|jsx)\" --languageFiles \"./src/i18n/ui/*.json\" --add",
    "i18n:remove": "vue-i18n-extract --vueFiles \"./src/**/*.?(js|ts|vue|astro|mdx|jsx)\" --languageFiles \"./src/i18n/ui/*.json\" --remove",
    "i18n:markdown": "node src/scripts/generate-markdown-content.mjs",
    "test": "vitest run --config test/unit/vitest.config.ts",
    "test:watch": "vitest --config test/unit/vitest.config.ts",
    "test:e2e": "playwright test --config test/e2e/playwright.config.ts"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/markdoc": "^0.15.10",
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/vue": "^5.1.4",
    "@eslint/js": "9.39.4",
    "@headlessui/vue": "^1.7.23",
    "@heroicons/vue": "^2.2.0",
    "@intlify/eslint-plugin-vue-i18n": "4.1.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@typescript-eslint/eslint-plugin": "8.29.1",
    "@typescript-eslint/parser": "8.29.1",
    "@vueuse/core": "^14.2.1",
    "astro": "^5.18.0",
    "eslint-import-resolver-typescript": "3.10.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-vue": "9.33.0",
    "i18next": "^25.8.14",
    "i18next-fs-backend": "^2.6.1",
    "lucide-vue-next": "^0.561.0",
    "nanostores": "^1.1.1",
    "remark": "^15.0.1",
    "remark-github-blockquote-alert": "^1.3.1",
    "sharp": "^0.34.5",
    "tailwindcss": "4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.49.0",
    "unist-util-visit": "^5.1.0",
    "vue": "^3.5.29",
    "vue-i18n": "^11.2.8"
  },
  "pnpm": {
    "overrides": {
      "@vue/devtools-kit": "^7.7.8",
      "glob": "^13.0.0",
      "js-yaml": "^4.1.1",
      "lodash": "^4.17.23",
      "mdast-util-to-hast": "^13.2.1",
      "@eslint/plugin-kit": "^0.3.4",
      "@modelcontextprotocol/sdk": "^1.27.1"
    }
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@playwright/test": "^1.58.2",
    "@sentry/astro": "^10.42.0",
    "@sentry/browser": "^10.42.0",
    "@spotlightjs/astro": "^3.2.6",
    "@spotlightjs/sidecar": "^2.5.0",
    "@spotlightjs/spotlight": "^4.10.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/devtools-kit": "^7.7.9",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.2",
    "glob": "^13.0.6",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "prettier": "3.5.3",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "prettier-plugin-vue": "1.1.6",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.4.0",
    "vue-i18n-extract": "^2.0.7",
    "vue-tsc": "^2.2.12"
  }
}
